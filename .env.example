# ── AirteleBots Environment Variables ──
# Copy this to .env and fill in your values.
# Each bot reads its own config, but here's the full reference.

# ── ytd-bot ──
# TELEGRAM_BOT_TOKEN="your_ytd_bot_token"

# ── know-bot ──
# TELEGRAM_BOT_TOKEN="your_know_bot_token"
# ALLOWED_USERS="123456789,987654321"   # optional
# ALLOW_ALL="true"                       # default: true
# GDRIVE_ENABLED="true"
# GDRIVE_FOLDER_NAME="Know_Bot_Knowledge"

# ── volcabu-bot (English Dictionary v1) ──
# TELEGRAM_BOT_TOKEN="your_volcabu_bot_token"
# HERMES_API_BASE="http://localhost:8642/v1"
# HERMES_API_KEY="hermes-api-key-local"
# HERMES_MODEL="hermes-agent"

# ── apolloew-bot (English Dictionary v2) ──
# TELEGRAM_BOT_TOKEN="your_apolloew_bot_token"
# HERMES_API_BASE="http://localhost:8642/v1"
# HERMES_API_KEY="hermes-api-key-local"
# HERMES_MODEL="hermes-agent"

# ── translate-bot (中翻英 @Ecche_bot) ──
# TELEGRAM_BOT_TOKEN="your_translate_bot_token"

# ── yt-shadow-bot ──
# TELEGRAM_BOT_TOKEN="your_yt_shadow_bot_token"
# TRANSCRIPT_LANGUAGE="en"

# ── tts-bot (edge-tts) ──
# TELEGRAM_BOT_TOKEN="your_tts_bot_token"
