# English Dictionary Bot — Environment Configuration
# Copy this file to .env and fill in your settings

# REQUIRED: Create a new bot via @BotFather on Telegram and get its token
# The token must be from a DIFFERENT bot than Hermes uses
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Hermes API Server (running on localhost:8642)
HERMES_API_KEY=hermes-api-key-local
HERMES_API_BASE=http://localhost:8642/v1
HERMES_MODEL=hermes-agent

# Access control
ALLOW_ALL=true
# ALLOWED_USERS=123456789,987654321
