# Know_Bot Configuration
# Copy to .env and fill in your values

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Optional: Allow all users (true) or restrict to ALLOWED_USERS list
ALLOW_ALL=true

# Optional: Comma-separated Telegram user IDs (when ALLOW_ALL=false)
# ALLOWED_USERS=123456789,987654321

# Optional: Enable Google Drive sync (requires GAPI setup)
GDRIVE_ENABLED=true

# Optional: Google Drive folder name for storage
# GDRIVE_FOLDER_NAME=Know_Bot_Knowledge